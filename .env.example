# =============================================================================
# ULTIMATE RESEARCH AGENT - ENVIRONMENT CONFIGURATION
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Search API
# Browserbase Search is the primary provider
# Docs: https://docs.browserbase.com/features/search
# -----------------------------------------------------------------------------
BROWSERBASE_API_KEY=your_browserbase_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Search fallback
# Serper is used only if Browserbase Search fails or is unavailable
# Get your free API key at: https://serper.dev
# Free tier: 2,500 searches/month
# -----------------------------------------------------------------------------
SERPER_API_KEY=your_serper_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL BUT RECOMMENDED: Premium Web Scraping
# Get your free API key at: https://firecrawl.dev
# Free tier: 500 credits (enough for ~100 research queries)
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# -----------------------------------------------------------------------------
# OPTIONAL: Cloud LLM Fallback (not recommended)
# Only used if Ollama is not available
# Get your free API key at: https://makersuite.google.com/app/apikey
# Free tier: 20 requests/day
# -----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here

# -----------------------------------------------------------------------------
# OLLAMA CONFIGURATION (Local LLM)
# -----------------------------------------------------------------------------
# URL for Ollama API (default: http://localhost:11434)
OLLAMA_URL=http://localhost:11434

# Model to use (default: llama3.2)
# Options: llama3.2, mistral, deepseek-r1:7b, gemma2:9b, etc.
OLLAMA_MODEL=llama3.2

# Timeout for LLM requests in seconds (default: 45)
OLLAMA_TIMEOUT=45

# -----------------------------------------------------------------------------
# OUTPUT CONFIGURATION
# -----------------------------------------------------------------------------
# Directory to save research outputs
OUTPUT_DIR=./research_agent/outputs

# Maximum number of sources to fetch (default: 5)
MAX_SOURCES=5

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# Log level: DEBUG, INFO, WARNING, ERROR (default: INFO)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Enable Firecrawl for deep scraping (default: true)
ENABLE_FIRECRAWL=true

# Enable Reddit search for discussions (default: true)
ENABLE_REDDIT=true

# -----------------------------------------------------------------------------
# BROWSER SETTINGS (for future browser-based features)
# -----------------------------------------------------------------------------
# User agent string for web requests
USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.0"
